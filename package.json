{
  "name": "suryabulusu-website",
  "version": "1.0.0",
  "description": "Personal website and blog",
  "type": "module",
  "scripts": {
    "lint": "eslint \"eleventy.config.js\" \"src/**/*.js\"",
    "format": "prettier --write \"**/*.{css,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{css,js,json,md,yml,yaml}\"",
    "prepare": "husky",
    "build": "eleventy",
    "dev": "eleventy --serve"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "lint-staged": {
    "*.{css,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
